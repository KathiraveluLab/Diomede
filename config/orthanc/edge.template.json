{
    "Name": "Orthanc_Edge",
    "DicomAet": "Orthanc_Edge",
    "DicomCheckCalledAet": true,
    "DicomCheckCallingAet": true,
    "RemoteAccessAllowed": true,
    "AuthenticationEnabled": true,
    "RegisteredUsers": {"${orthanc_user}": "${orthanc_password}"},
    "DicomPort": 4242,
    "HttpPort": 8042,
    "HttpServerEnabled": true,
    "DicomServerEnabled": true,
    "DicomTlsEnabled": true,
    "SslEnabled": true,
    "DicomTlsCertificate": "/etc/orthanc/certs/server.crt",
    "DicomTlsPrivateKey": "/etc/orthanc/certs/server.key",
    "DicomTlsTrustedCertificates": "/etc/orthanc/certs/ca.pem",
    "SslCertificate": "/etc/orthanc/certs/combined.pem",
    "DicomTlsRemoteCertificateRequired": true,
    "HttpCompressionEnabled": true,
    "MaximumStorageSize": 10000,
    "IngestTranscodingEnabled": false,
    "StorageCompression": true,
    "StorageDirectory": "/var/lib/orthanc/db",
    "RestApiWriteToFileSystemEnabled": true,
    "DicomModalities": {
        "us":   ["Orthanc_US",   "orthanc-us",   4242],
        "eu":   ["Orthanc_EU",   "orthanc-eu",   4242],
        "asia": ["Orthanc_ASIA", "orthanc-asia", 4242],
        "af":   ["Orthanc_AF",   "orthanc-af",   4242]
    }
}
